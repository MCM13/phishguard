ANTHROPIC_API_KEY=your_key_here

# VirusTotal API v3 (plan Public API gratuito para uso personal/educativo).
# Obtén la clave en: https://www.virustotal.com/gui/my-apikey
# Límites del plan gratis: ~4 peticiones/minuto y 500/día.
VIRUSTOTAL_API_KEY=your_virustotal_key_here

URLSCAN_API_KEY=your_key_here

# Modelo de Claude a utilizar. Ver README para la lista completa.
# Recomendado: claude-sonnet-4-6 (mejor balance calidad/coste/velocidad)
# Alternativas: claude-opus-4-6 (máxima calidad), claude-haiku-4-5-20251001 (más rápido)
CLAUDE_MODEL=claude-sonnet-4-6

# Límites de llamadas a Claude (protege créditos). 0 = sin límite en esa ventana.
ANTHROPIC_MAX_PER_HOUR=10
ANTHROPIC_MAX_PER_DAY=20

# Lista CSV de orígenes permitidos por CORS. NUNCA dejar "*" en producción.
# En desarrollo incluye localhost y 127.0.0.1 (el navegador los trata como orígenes distintos).
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Solo en Render / producción (panel Environment del backend) ---
# URL pública EXACTA del frontend (https, sin barra final). Se añade sola a CORS.
# FRONTEND_URL=https://phishguard.cmmario.com
# ALLOWED_ORIGINS=https://phishguard.cmmario.com
# Si tienes dominio propio, inclúyelo también: https://tudominio.com,https://www.tudominio.com
# SQLite escribible en Render (obligatorio si no usas disco persistente):
# DATABASE_URL=sqlite:////tmp/phishguard.db

# Opcional: URL pública del backend que verá el navegador (build-time del frontend).
# Si despliegas en un VPS, cámbialo por http://TU_IP:8000 o https://api.tu-dominio.com.
VITE_API_URL=http://localhost:8000
